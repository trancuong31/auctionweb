msgstr "Chỉ được thêm người tham gia mới khi phiên đang diễn ra. Không được phép xóa người tham gia."

msgid "You can only modify your own information"
msgstr "Bạn chỉ có thể chỉnh sửa thông tin của chính mình"

msgid "You don't have permission to create auction!"
msgstr "Bạn không có quyền tạo phiên đấu giá!"

msgid "Your bid of {amount} has been voided (Reason: {reason}). Please submit a new bid."
msgstr "Lượt đặt giá {amount} của bạn đã bị hủy (Lý do: {reason}). Vui lòng gửi lượt đặt giá mới."

msgid "end_time must be after start_time"
msgstr "end_time phải sau start_time"

msgid "index.html not found"
msgstr "Không tìm thấy index.html"

msgid "start_time must be before end_time"
msgstr "start_time phải trước end_time"

msgid "Email already exists"
msgstr "Email đã tồn tại."
