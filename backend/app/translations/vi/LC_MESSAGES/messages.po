msgstr "Trạng thái phải là 0 (không hoạt động) hoặc 1 (hoạt động)"

msgid "User status updated to {data.status}."
msgstr "Trạng thái người dùng đã được cập nhật thành {data.status}."

msgid "User updated successfully."
msgstr "Cập nhật người dùng thành công."

msgid "User deleted successfully."
msgstr "Xóa người dùng thành công."

msgid "You are not allowed to edit this auction"
msgstr "Bạn không có quyền chỉnh sửa phiên đấu giá này"

msgid "You are not allowed to edit auctions"
msgstr "Bạn không có quyền chỉnh sửa các phiên đấu giá"

msgid "Your new price must be at least one price step away from your old price."
msgstr "Giá mới của bạn phải cách giá cũ ít nhất một bước giá."

msgid "Admin cannot modify Super Admin information"
msgstr "Admin không có quyền chỉnh sửa thông tin của supper Admin và Admin"

msgid "Admin cannot delete Super Admin information"
msgstr "Admin không có quyền xóa tài khoản Supper Admin và Admin"

msgid "Super Admin cannot delete Super Admin information"
msgstr "Super Admin không thể xóa được tài khoản Super Admin"

msgid "Admin cannot modify Super Admin, Admin information"
msgstr "Admin không có quyền thay đổi thông tin của tài khoản Super Admin và Admin"

msgid "Phone number must be 10 digits"
msgstr "Số điện thoại phải 10 kí tự"

msgid "Admin or Super Admin not allowed to bid"
msgstr "Admin và Super admin không được phép tham gia đấu giá"

msgid "Super Admin cannot modify Super Admin information"
msgstr "Super admin không thể chỉnh sửa thông tin của Supper admin"

msgid "You don't have permission to create category!"
msgstr "Bạn không có quyền tạo danh mục!"

msgid "Category name already exists"
msgstr "Danh mục đã tồn tại"

msgid "User not invited to bid"
msgstr "Bạn không được mời tham gia đấu giá"

msgid "An error occurred while resetting password"
msgstr "Đã xảy ra lỗi khi đặt lại mật khẩu"

msgid "Bid amount must be at least the starting price"
msgstr "Giá thầu phải ít nhất bằng giá khởi điểm"

msgid "Bid not found"
msgstr "Không tìm thấy lượt đặt giá"

