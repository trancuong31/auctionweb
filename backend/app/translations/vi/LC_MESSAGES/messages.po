msgstr "Phiên đấu giá không hoạt động"

msgid "User not allowed to bid"
msgstr "Bạn không được phép đặt giá"

msgid "Bid amount is invalid. Your bid must be at least {min_bid:,.0f}$ {min_bid_msg}"
msgstr "Số tiền đặt giá không hợp lệ. Giá của bạn phải ít nhất là {min_bid:,.0f}$ {min_bid_msg}"

msgid "User has already placed a bid for this auction"
msgstr "Bạn đã đặt giá cho phiên đấu giá này rồi"

msgid "You have successfully placed a bid of  {bid_in.bid_amount:,.0f}$ on auction {auction.title}."
msgstr "Bạn đã đặt giá thành công {bid_in.bid_amount:,.0f}$ cho phiên đấu giá {auction.title}."

msgid "Incorrect email or password"
msgstr "Email hoặc mật khẩu không đúng"

msgid "User is inactive or banned"
