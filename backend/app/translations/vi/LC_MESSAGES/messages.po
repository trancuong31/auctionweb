msgstr "Không tìm thấy lượt đặt giá hoặc tệp đính kèm"

msgid "Cannot update an ended auction."
msgstr "Không thể cập nhật phiên đấu giá đã kết thúc."

msgid "Category deleted successfully."
msgstr "Xóa danh mục thành công."

msgid "Category not found"
msgstr "Không tìm thấy danh mục"

msgid "Category updated successfully."
msgstr "Cập nhật danh mục thành công."

msgid "Database error: {error}"
msgstr "Lỗi cơ sở dữ liệu: {error}"

msgid "Error while creating auction: {error}"
msgstr "Có lỗi xảy ra khi tạo phiên đấu giá: {error}"

msgid "If the email exists, a reset link has been sent"
msgstr "Nếu email tồn tại, liên kết đặt lại mật khẩu đã được gửi"

msgid "Image file too large (max 5MB): {filename}"
msgstr "Ảnh vượt quá dung lượng cho phép (tối đa 5MB): {filename}"

msgid "Internal server error: {error}"
msgstr "Lỗi máy chủ nội bộ: {error}"

msgid "Invalid auction_type value"
msgstr "Giá trị auction_type không hợp lệ"

msgid "Invalid authorization header"
msgstr "Header ủy quyền không hợp lệ"

msgid "Invalid image file type: {filename}"
msgstr "Định dạng ảnh không hợp lệ: {filename}"

msgid "Invalid or expired reset token"
msgstr "Mã đặt lại mật khẩu không hợp lệ hoặc đã hết hạn"

msgid "Invalid reset token"
msgstr "Mã đặt lại mật khẩu không hợp lệ"

msgid "Invalid token"
msgstr "Token không hợp lệ"

msgid "Not Found"
msgstr "Không tìm thấy"

msgid "Only Admin or Super Admin can void bids"
msgstr "Chỉ Admin hoặc Super Admin mới có thể hủy lượt đặt giá"

msgid "Password has been reset successfully"
msgstr "Đặt lại mật khẩu thành công"

msgid "Set read successful!"
msgstr "Đánh dấu đã đọc thành công!"

msgid "Unexpected error: {error}"
msgstr "Lỗi không mong muốn: {error}"

msgid "User ID not found in token"
msgstr "Không tìm thấy User ID trong token"

msgid "User is inactive"
msgstr "Người dùng đang bị vô hiệu hóa"

