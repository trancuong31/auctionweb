msgstr "Tìm kiếm theo tiêu đề phiên đấu giá"

msgid "Sắp xếp theo: title, created_at, start_time, end_time"
msgstr "Sắp xếp theo: tiêu đề, ngày tạo, thời gian bắt đầu, thời gian kết thúc"

msgid "Thứ tự sắp xếp: asc (A-Z), desc (Z-A)"
msgstr "Thứ tự sắp xếp: tăng dần (A-Z), giảm dần (Z-A)"

msgid "Số trang"
msgstr "Số trang"

