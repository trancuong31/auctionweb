msgid "Hello, World!"
msgstr "안녕하세요, 세상!"

msgid "Login"
msgstr "로그인"

msgid "Logout"
msgstr "로그아웃"

msgid "Username"
msgstr "사용자 이름"

msgid "Password"
msgstr "비밀번호"

msgid "Submit"
msgstr "제출"

msgid "User not found"
msgstr "사용자를 찾을 수 없습니다"

msgid "Invalid status value"
msgstr "유효하지 않은 상태 값입니다"

msgid "You don't have permison create auction!"
msgstr "경매를 생성할 권한이 없습니다!"

msgid "Auction title already exists"
msgstr "동일한 경매 제목이 이미 존재합니다"

msgid "No files provided"
msgstr "파일이 제공되지 않았습니다"

msgid "Invalid file name."
msgstr "유효하지 않은 파일 이름입니다."

msgid "Invalid image file type: {file.filename}"
msgstr "유효하지 않은 이미지 파일 형식입니다: {file.filename}"

msgid "Image file too large (max 5MB): {file.filename}"
msgstr "이미지 파일이 너무 큽니다 (최대 5MB): {file.filename}"

msgid "Total image URLs length too long (max 500 chars): {image_urls}"
msgstr "이미지 URL의 전체 길이가 너무 깁니다 (최대 500자): {image_urls}"

msgid "Internal server error: {str(e)}"
msgstr "내부 서버 오류: {str(e)}"

msgid "No filename provided"
msgstr "파일 이름이 제공되지 않았습니다"

msgid "Invalid excel file type"
msgstr "유효하지 않은 엑셀 파일 형식입니다"

msgid "Excel file too large (max 100MB)"
msgstr "엑셀 파일이 너무 큽니다 (최대 100MB)"

msgid "Auction or file not found"
msgstr "경매 또는 파일을 찾을 수 없습니다"

msgid "File not found on server"
msgstr "서버에서 파일을 찾을 수 없습니다"

msgid "Auction not found"
msgstr "경매를 찾을 수 없습니다"

msgid "0: ongoing, 1: upcoming, 2: ended"
msgstr "0: 진행 중, 1: 예정, 2: 종료됨"

msgid "Tìm kiếm theo title auction"
msgstr "경매 제목으로 검색"

msgid "Sắp xếp theo: title, created_at, start_time, end_time"
msgstr "정렬 기준: 제목, 생성일, 시작 시간, 종료 시간"

msgid "Thứ tự sắp xếp: asc (A-Z), desc (Z-A)"
msgstr "정렬 순서: asc (오름차순 A‑Z), desc (내림차순 Z‑A)"

msgid "Số trang"
msgstr "페이지 번호"

msgid "Số item trên mỗi trang"
msgstr "페이지당 항목 수"

msgid "Từ ngày"
msgstr "시작일"

msgid "Đến ngày"
msgstr "종료일"

msgid "Auction is not active"
msgstr "경매가 활성 상태가 아닙니다"

msgid "User not allowed to bid"
msgstr "입찰할 권한이 없습니다"

msgid "Bid amount is invalid. Your bid must be at least {min_bid:,.0f}$ {min_bid_msg}"
msgstr "잘못된 입찰 금액입니다. 입찰 금액은 최소 {min_bid:,.0f}$이어야 합니다 {min_bid_msg}"

msgid "User has already placed a bid for this auction"
msgstr "사용자가 이 경매에 이미 입찰했습니다"

msgid "You have successfully placed a bid of  {bid_in.bid_amount:,.0f}$ on auction {auction.title}."
msgstr "경매 {auction.title}에 {bid_in.bid_amount:,.0f}$ 입찰이 성공적으로 완료되었습니다."

msgid "Incorrect email or password"
msgstr "이메일 또는 비밀번호가 올바르지 않습니다"

msgid "User is inactive or banned"
msgstr "사용자가 비활성 상태이거나 정지되었습니다"

msgid "Account already registered"
msgstr "이미 등록된 계정입니다"

msgid "Invalid refresh token"
msgstr "유효하지 않은 리프레시 토큰입니다"

msgid "You don't have permison watch users!"
msgstr "사용자 목록을 볼 권한이 없습니다!"

msgid "Permission denied"
msgstr "권한이 거부되었습니다"

msgid "Status must be 0 (disactive) or 1 (active)"
msgstr "상태는 0(비활성) 또는 1(활성)이어야 합니다"

msgid "User status updated to {data.status}."
msgstr "사용자 상태가 {data.status}(으)로 업데이트되었습니다."

msgid "User updated successfully."
msgstr "사용자가 성공적으로 업데이트되었습니다."

msgid "User deleted successfully."
msgstr "사용자가 성공적으로 삭제되었습니다."

msgid "You are not allowed to edit this auction"
msgstr "이 경매를 수정할 권한이 없습니다"

msgid "You are not allowed to edit auctions"
msgstr "경매를 수정할 권한이 없습니다"

msgid "Your new price must be at least one price step away from your old price."
msgstr "새 가격은 이전 가격과 최소 한 단계 이상 차이가 있어야 합니다."

msgid "Admin cannot modify Super Admin information"
msgstr "관리자는 슈퍼 관리자 정보를 수정할 수 없습니다"

msgid "Admin cannot delete Super Admin information"
msgstr "관리자는 슈퍼 관리자 정보를 삭제할 수 없습니다."

msgid "Super Admin cannot delete Super Admin information"
msgstr "슈퍼 관리자는 슈퍼 관리자를 삭제할 수 없습니다."

msgid "Admin cannot modify Super Admin, Admin information"
msgstr "관리자는 슈퍼 관리자, 관리자 정보를 수정할 수 없습니다."

msgid "Phone number must be 10 digits"
msgstr "전화번호는 10자리여야 합니다."

msgid "Admin or Super Admin not allowed to bid"
msgstr "관리자 또는 슈퍼 관리자는 입찰할 수 없습니다"

msgid "Super Admin cannot modify Super Admin information"
msgstr "슈퍼 관리자는 슈퍼 관리자 정보를 수정할 수 없습니다"

msgid "You don't have permission to create category!"
msgstr "카테고리를 생성할 권한이 없습니다!"

msgid "Category name already exists"
msgstr "카테고리 이름이 이미 존재합니다"

msgid "User not invited to bid"
msgstr "사용자가 입찰에 초대되지 않았습니다"

msgid "An error occurred while resetting password"
msgstr "비밀번호 재설정 중 오류가 발생했습니다"

msgid "Bid amount must be at least the starting price"
msgstr "입찰 금액은 시작가 이상이어야 합니다"

msgid "Bid not found"
msgstr "입찰 정보를 찾을 수 없습니다"

msgid "Bid or file not found"
msgstr "입찰 또는 파일을 찾을 수 없습니다"

msgid "Cannot update an ended auction."
msgstr "종료된 경매는 수정할 수 없습니다."

msgid "Category deleted successfully."
msgstr "카테고리가 성공적으로 삭제되었습니다."

msgid "Category not found"
msgstr "카테고리를 찾을 수 없습니다"

msgid "Category updated successfully."
msgstr "카테고리가 성공적으로 수정되었습니다."

msgid "Database error: {error}"
msgstr "데이터베이스 오류: {error}"

msgid "Error while creating auction: {error}"
msgstr "경매 생성 중 오류가 발생했습니다: {error}"

msgid "If the email exists, a reset link has been sent"
msgstr "이메일이 존재하면 비밀번호 재설정 링크가 전송되었습니다"

msgid "Image file too large (max 5MB): {filename}"
msgstr "이미지 파일이 너무 큽니다(최대 5MB): {filename}"

msgid "Internal server error: {error}"
msgstr "내부 서버 오류: {error}"

msgid "Invalid auction_type value"
msgstr "유효하지 않은 auction_type 값입니다"

msgid "Invalid authorization header"
msgstr "잘못된 인증 헤더입니다"

msgid "Invalid image file type: {filename}"
msgstr "잘못된 이미지 파일 형식입니다: {filename}"

msgid "Invalid or expired reset token"
msgstr "재설정 토큰이 유효하지 않거나 만료되었습니다"

msgid "Invalid reset token"
msgstr "유효하지 않은 재설정 토큰입니다"

msgid "Invalid token"
msgstr "유효하지 않은 토큰입니다"

msgid "Not Found"
msgstr "찾을 수 없습니다"

msgid "Only Admin or Super Admin can void bids"
msgstr "Admin 또는 Super Admin만 입찰을 무효 처리할 수 있습니다"

msgid "Password has been reset successfully"
msgstr "비밀번호가 성공적으로 재설정되었습니다"

msgid "Set read successful!"
msgstr "읽음 처리되었습니다!"

msgid "Unexpected error: {error}"
msgstr "예기치 않은 오류: {error}"

msgid "User ID not found in token"
msgstr "토큰에서 사용자 ID를 찾을 수 없습니다"

msgid "User is inactive"
msgstr "비활성 사용자입니다"

msgid "You can only add new participants to an ongoing auction. Removing participants is not allowed."
msgstr "진행 중인 경매에는 참가자만 추가할 수 있으며 제거는 허용되지 않습니다."

msgid "You can only modify your own information"
msgstr "본인 정보만 수정할 수 있습니다"

msgid "You don't have permission to create auction!"
msgstr "경매를 생성할 권한이 없습니다!"

msgid "Your bid of {amount} has been voided (Reason: {reason}). Please submit a new bid."
msgstr "{amount} 입찰이 취소되었습니다 (사유: {reason}). 새 입찰을 제출해 주세요."

msgid "end_time must be after start_time"
msgstr "end_time은 start_time보다 늦어야 합니다"

msgid "index.html not found"
msgstr "index.html을 찾을 수 없습니다"

msgid "start_time must be before end_time"
msgstr "start_time은 end_time보다 빨라야 합니다"

msgid "Email already exists"
msgstr "이메일이 이미 존재합니다."
